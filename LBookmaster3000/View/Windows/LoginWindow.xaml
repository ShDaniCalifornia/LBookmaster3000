<Window x:Class="LBookmaster3000.View.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LBookmaster3000.View.Windows"
        mc:Ignorable="d"
        Title="Login Window" Height="400" Width="600"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid Margin="70">
            <Grid.RowDefinitions>
                <RowDefinition Height="1*" />
                <RowDefinition Height="10" />
                <RowDefinition Height="75" />
                <RowDefinition Height="10" />
                <RowDefinition Height="1*" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="1*" />

            </Grid.ColumnDefinitions>

            <Button Name="BtnLogin" Grid.Row="5" Grid.Column="2" Click="BtnLogin_Click"
                Margin="5" Content="Login" FontSize="2" />
            
            <Button Name="BtnCancel" Grid.Row="5" Grid.Column="4" Click="BtnCancel_Click"
                Margin="5" Content="Cancel" />
            
            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       FontSize="20"
                       Text="Username">
            </TextBlock>
            
            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       FontSize="20"
                       Text="Password">
            </TextBlock>

            <TextBox Name="TbUsername"
                    Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="3"
                    Margin="10" BorderBrush="Black" TextChanged="TextBox_TextChanged">
            </TextBox>

            <PasswordBox Name="PbPassword" Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="3"
                     PasswordChar="*"
                     Margin="10"/>

        </Grid>
    </Grid>
</Window>

<Window x:Class="LBookmaster3000.View.Windows.Circulation"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LBookmaster3000.View.Windows"
        mc:Ignorable="d"
        MinHeight="720" MinWidth="1080"
        Title="Circulation" Height="900" Width="1600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="500"/>
            <ColumnDefinition Width="1*"/>

        </Grid.ColumnDefinitions>

        <!-- Menu -->
        <Menu Grid.ColumnSpan="2">
            <MenuItem Header="File"
                      FontSize="25">
                <MenuItem Name="LoginMi" Header="Login" Click="LoginMi_Click"/>
                <MenuItem Name="LogoutMi" Header="Logout" Click="LogoutMi_Click"/>
                <MenuItem Name="CLoseMi" Header="Close" Click="CLoseMi_Click"/>
            </MenuItem>
            <MenuItem Name="LibraryMi" Header="Library"
                      FontSize="25">
                <MenuItem Name="ManageCustomersMi" Header="Manage Customers" Click="ManageCustomersMi_Click"/>
                <MenuItem Name="CirculationMi" Header="Circulation" Click="CirculationMi_Click"/>
                <MenuItem Name="ReportsMi" Header="Reports" Click="ReportsMi_Click"/>
            </MenuItem>
        </Menu>

        <!-- Левая часть -->
        <Grid Grid.Row="1" 
              Grid.RowSpan="2"
              Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="200"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <Image Source="/Resources/Images/logo.png"
                   Grid.Row="0" Margin="0,0,-300,0"/>

            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Grid.ColumnSpan="3"
                       Text="Customer ID"/>

            <TextBox Name="CustomerIDTb" Grid.Row="4" Grid.ColumnSpan="3"
                     Grid.Column="0"
                     Margin="10 0 20 0"
                     BorderBrush="Black" TextChanged="CustomerIDTb_TextChanged"/>


            <Button Name ="CirculationBtn" Click="CirculationBtn_Click"
                    Content="Circulation"
                    Grid.Column="2" 
                    Grid.Row="6"
                    BorderBrush="Black"/>

            <TextBlock Grid.Row="8" Grid.ColumnSpan="3" Text="{Binding Customer.Name}"/>

            <TextBlock Grid.Row="9" Text="{Binding Customer.ID}"/>

            <TextBlock Grid.Row="11" Grid.ColumnSpan="3" Text="{Binding Customer.Address}"/>

            <TextBlock Grid.Row="12" Grid.Column="0" Text="{Binding Customer.Zip}"/>

            <TextBlock Grid.Row="12" Grid.Column="2" Text="{Binding Customer.City}"/>

            <Button Grid.Row="13" Grid.Column="3" Margin="150 0 20 0" Content="Edit..."/>
        </Grid>

        <!-- Правая часть -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="200"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5" Text="Issue / Return" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Book ID"/>

            <TextBox Grid.Row="3" Grid.Column="2"/>

            <Button Grid.Row="3" Grid.Column="5" Content="Issue"/>

            <Button Grid.Row="5" Grid.Column="5" Content="Return"/>

            <TextBlock Grid.Row="5" Grid.Column="2" Text="{Binding Book.Id}"/>

            <TextBlock Grid.Row="7" Grid.Column="0" Text="Current Issues"/>
            
            <!-- Listview 1 -->
            <ListView Name="CurrentIssuesLv" Grid.Row="8" Grid.ColumnSpan="5"
             SelectionChanged="CurrentIssuesLv_SelectionChanged">
                <!-- Переводим ListView в табличный вид-->
                <ListView.View>
                    <GridView>
                        <!-- Создаем столбцы -->
                        <GridViewColumn Header="Title" DisplayMemberBinding="{Binding Title}"/>
                        <GridViewColumn Header="Date of issue" DisplayMemberBinding="{Binding Title}"/>
                        <GridViewColumn Header="Return until" DisplayMemberBinding="{Binding Title}"/>
                    </GridView>
                </ListView.View>
            </ListView>


            <Button Grid.Row="10" Grid.Column="4" Content="Renew"/>

            <TextBlock Grid.Row="12" Grid.Column="0" Text="History"/>
            
            <!-- Listview 2 -->
            <ListView Name="HistoryLv" Grid.Row="13" Grid.ColumnSpan="5"
             SelectionChanged="HistoryLv_SelectionChanged">
                <!-- Переводим ListView в табличный вид-->
                <ListView.View>
                    <GridView>
                        <!-- Создаем столбцы -->
                        <GridViewColumn Header="Title" DisplayMemberBinding="{Binding Title}"/>
                        <GridViewColumn Header="Date of issue" DisplayMemberBinding="{Binding Title}"/>
                        <GridViewColumn Header="Return until" DisplayMemberBinding="{Binding Title}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </Grid>
</Window>

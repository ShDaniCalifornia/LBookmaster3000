<Window x:Class="LBookmaster3000.View.Windows.BookAuthorsDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LBookmaster3000.View.Windows"
        mc:Ignorable="d"
        Width="400" 
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="200"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <ComboBox Name="AuthorsCmb"
                      SelectionChanged="AuthorsCmb_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} {1}">
                                    <Binding Path="Author.Lastname"/>
                                    <Binding Path="Author.Firstname"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Grid.Row="2">
                <TextBlock.Text>
                    <MultiBinding StringFormat="{}{0:dd MMMM yyyy} - {1:dd MMMM yyyy}">
                        <Binding Path="Author.BirthDate"/>
                        <Binding Path="Author.DeathDate"/>
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>
            <TextBlock Grid.Row="4" Text="Биография"/>

            <ScrollViewer Grid.Row="6">
                <TextBlock Grid.Row="6" Text="{Binding Author.Bio}"/>
            </ScrollViewer>
            
            <TextBlock Grid.Row="8">
            <Hyperlink NavigateUri="{Binding Author.Wikipedia}"
                       RequestNavigate="Hyperlink_RequestNavigate">
                Перейти на Wikipedia
            </Hyperlink>
            </TextBlock>
            <Button Name="CloseBtn" Grid.Row="10" Content="Close"
                HorizontalAlignment="Left" Click="CloseBtn_Click"/>
        </Grid>
    </Grid>
</Window>
